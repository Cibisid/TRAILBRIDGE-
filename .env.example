# =============================================
# TrialBridge Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =============================================

# --- App ---
APP_NAME=TrialBridge
APP_ENV=development   # development | staging | production
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trialbridge
POSTGRES_USER=trialbridge_user
POSTGRES_PASSWORD=your-strong-db-password
DATABASE_URL=postgresql+asyncpg://trialbridge_user:your-strong-db-password@postgres:5432/trialbridge

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://:your-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:your-redis-password@redis:6379/2

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this-too
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# --- AWS (for production) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trialbridge-data

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- ClinicalTrials.gov ---
CTGOV_API_BASE_URL=https://clinicaltrials.gov/api/v2
CTGOV_PAGE_SIZE=100
CTGOV_MAX_TRIALS=50000

# --- NLP Models ---
SCISPACY_MODEL=en_core_sci_lg
BIOBERT_MODEL=microsoft/BiomedNLP-BiomedBERT-base-uncased-abstract
EMBEDDING_DIMENSION=768

# --- Monitoring ---
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | text
